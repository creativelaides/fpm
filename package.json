{
  "name": "fpm",
  "version": "0.2.0",
  "private": true,
  "description": "A Windows-native Rust wrapper around PyManager for per-session Python version switching",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "cz": "cz",
    "changeset": "changeset",
    "version:prepare": "changeset version && node .ci/sync-cargo-version.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7"
  }
}
